#!/usr/bin/env bash
# GEANT4PHYSICS - Interactive Geant4 project scaffolding tool

set -e

REPO_URL="https://github.com/sugamanugrah/PROJECT_NAME.git"

# ---------- Colors ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${CYAN}➜${NC} $1"; }
success() { echo -e "${GREEN}✔${NC} $1"; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }
error()   { echo -e "${RED}✖${NC} $1"; }

clear
echo -e "${BOLD}${CYAN}"
echo "=================================================="
echo "        GEANT4PHYSICS — Project Setup"
echo "=================================================="
echo -e "${NC}"

validate_name() {
  local name="$1"
  local label="$2"
  if [ -z "$name" ]; then
    error "$label cannot be empty."
    return 1
  fi
  if [[ "$name" =~ [[:space:]] ]]; then
    error "$label cannot contain spaces."
    return 1
  fi
  if [[ ! "$name" =~ ^[A-Za-z0-9_-]+$ ]]; then
    error "$label can only contain letters, numbers, underscores, and hyphens."
    return 1
  fi
  return 0
}

# ---------- Input 1: Project Name ----------
while true; do
  read -p "$(echo -e ${BOLD}"Enter your Project Name (e.g. MySimulation): "${NC})" PROJECT_NAME_NEW
  validate_name "$PROJECT_NAME_NEW" "Project name" && break
done

# ---------- Input 2: Executable Name (optional) ----------
EXE_OLD="next"
EXE_NEW="$EXE_OLD"

while true; do
  read -p "$(echo -e ${BOLD}"Do you want to change the executable name? (Y/N): "${NC})" CHANGE_EXE
  case "$CHANGE_EXE" in
    [Yy])
      while true; do
        read -p "$(echo -e ${BOLD}"Enter your new Executable Name (e.g. mysim): "${NC})" EXE_NEW
        validate_name "$EXE_NEW" "Executable name" && break
      done
      break
      ;;
    [Nn])
      info "Keeping default executable name: '${EXE_OLD}'"
      break
      ;;
    *)
      warn "Please enter Y or N."
      ;;
  esac
done

TARGET_DIR="$PROJECT_NAME_NEW"

# ---------- Check if folder already exists ----------
if [ -d "$TARGET_DIR" ]; then
  warn "A folder named '${TARGET_DIR}' already exists."
  read -p "Overwrite it? (y/N): " OVERWRITE
  if [[ "$OVERWRITE" =~ ^[Yy]$ ]]; then
    rm -rf "$TARGET_DIR"
    info "Removed existing folder."
  else
    error "Aborted. Choose a different project name and try again."
    exit 1
  fi
fi

# ---------- Confirmation ----------
echo ""
echo -e "${BOLD}Summary:${NC}"
echo -e "  Project Name     : ${GREEN}${PROJECT_NAME_NEW}${NC}"
echo -e "  Executable Name  : ${GREEN}${EXE_NEW}${NC}"
echo -e "  Target Directory : ${GREEN}./${TARGET_DIR}${NC}"
echo ""
read -p "Proceed with setup? (Y/n): " CONFIRM
if [[ "$CONFIRM" =~ ^[Nn]$ ]]; then
  error "Setup cancelled."
  exit 1
fi
echo ""

# ---------- Clone ----------
info "Cloning template repo into '${TARGET_DIR}'..."
if git clone --quiet "$REPO_URL" "$TARGET_DIR" 2>/dev/null; then
  success "Repo cloned."
else
  error "Failed to clone repo. Check your internet connection or repo URL."
  exit 1
fi

cd "$TARGET_DIR"
rm -rf .git

# ---------- Replace PROJECT_NAME ----------
info "Renaming project references to '${PROJECT_NAME_NEW}'..."
grep -rlZ "PROJECT_NAME" --include="*.txt" --include="*.md" --include="*.mac" \
    --include="*.cc" --include="*.hh" --include="*.in" --include="*.out" . 2>/dev/null \
    | xargs -0 -r sed -i "s/PROJECT_NAME/${PROJECT_NAME_NEW}/g"
success "Project name updated."

# ---------- Replace executable name (only if changed) ----------
if [ "$EXE_NEW" != "$EXE_OLD" ]; then
  info "Renaming executable '${EXE_OLD}' -> '${EXE_NEW}'..."
  sed -i "s/\bnext\b/${EXE_NEW}/g" CMakeLists.txt run.mac init_vis.mac vis.mac 2>/dev/null || true

  for ext in cc in out; do
    if [ -f "${EXE_OLD}.${ext}" ]; then
      mv "${EXE_OLD}.${ext}" "${EXE_NEW}.${ext}"
      sed -i "s/\b${EXE_OLD}\b/${EXE_NEW}/g" "${EXE_NEW}.${ext}"
    fi
  done
  success "Executable renamed."
else
  info "Executable name unchanged ('${EXE_OLD}')."
fi

# ---------- Build directory ----------
mkdir -p build
success "Build directory created."

# ---------- Done ----------
echo ""
echo "${GREEN}${BOLD}=================================================="
echo "  Setup complete!"
echo "==================================================${NC}"
echo ""
echo -e "${BOLD}Project '${PROJECT_NAME_NEW}' is ready in:${NC} ./${TARGET_DIR}"
echo ""
